{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build:mvp",
  "outputDirectory": "dist",
  "redirects": [{ "source": "/", "destination": "/booster/mvp/", "permanent": false }],
  "rewrites": [
    {
      "source": "/booster/mvp/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/booster/mvp/lovable-uploads/:path*",
      "destination": "/lovable-uploads/:path*"
    },
    {
      "source": "/booster/mvp/logos/:path*",
      "destination": "/logos/:path*"
    },
    {
      "source": "/booster/mvp/brand/:path*",
      "destination": "/brand/:path*"
    },
    {
      "source": "/booster/mvp/first-time-user.svg",
      "destination": "/first-time-user.svg"
    },
    {
      "source": "/booster/mvp/login-illustration.svg",
      "destination": "/login-illustration.svg"
    },
    {
      "source": "/booster/mvp/design-building-blocks-illustration.svg",
      "destination": "/design-building-blocks-illustration.svg"
    },
    {
      "source": "/booster/mvp/placeholder.svg",
      "destination": "/placeholder.svg"
    },
    {
      "source": "/booster/mvp/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/booster/mvp/favicon.svg",
      "destination": "/favicon.svg"
    },
    {
      "source": "/booster/mvp/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/booster/mvp",
      "destination": "/index.html"
    },
    {
      "source": "/booster/mvp/",
      "destination": "/index.html"
    },
    {
      "source": "/booster/mvp/:path*",
      "destination": "/index.html"
    }
  ]
}
